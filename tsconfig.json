{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "sourceMap": false,
    "target": "es6",
    "declaration": true,
    "declarationDir": "dist",
    "baseUrl": "./src",
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": false,
    "rootDir": "."
  },
  "include": [
    "**/*.ts"
  ]
}